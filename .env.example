# PUPOUS PDTS safe configuration template
# Copy to .env and replace placeholders locally.
# Never commit or publicly share the completed .env file.

SQL_HOST=127.0.0.1
SQL_DB_NAME=pup_ous_pdts
SQL_USER=pup_user
SQL_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD
SQL_ADMIN_USER=postgres
SQL_ADMIN_PASSWORD=REPLACE_WITH_POSTGRES_ADMIN_PASSWORD

APP_URL=http://localhost:3000
HTTPS_PORT=3443
CORS_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=

# Optional SMTP configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
